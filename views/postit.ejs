<% const body = `
<section class='py-5 text-center'>
  <div class='container'>
    <h1 class='display-5 fw-bold'>Post-it Board</h1>
    <p class='text-muted'>Ideas with their own unique color!</p>
  </div>
</section>

<div class='container pb-5'>
  <div class='row g-4 justify-content-center'>
    ${postits.map(p => `
      <div class='col-12 col-sm-6 col-md-4 col-lg-3 d-flex justify-content-center'>
        <div class='postit-square' style='background: ${p.color}'>
          <h4 class='fw-bold mb-2'>${p.title}</h4>
          <p>${p.desc}</p>
          <div class='mt-3 small text-dark opacity-75'>
            ${p.name}<br>${p.email}
          </div>
        </div>
      </div>
    `).join('')}
  </div>
</div>
` %>

<%- include('layout', { title: 'Board', body }) %>
